{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://team-memory-rbac.dev/contracts/v1/schema.json",
  "title": "Team Memory RBAC Contracts",
  "type": "object",
  "$defs": {
    "MemoryRelationType": {
      "type": "string",
      "enum": [
        "has",
        "depends_on",
        "relates_to",
        "refers_to",
        "contradicts",
        "supersedes",
        "next_is"
      ]
    },
    "MemoryObjectKind": {
      "type": "string",
      "enum": [
        "memory_entity",
        "memory_entity_branch",
        "memory_relation",
        "resource",
        "resource_chunk"
      ]
    },
    "MemoryAction": {
      "type": "string",
      "enum": [
        "read",
        "search",
        "traverse_relation",
        "import_resource",
        "write_resource_chunk",
        "index_resource",
        "write_entity",
        "write_entity_branch",
        "write_relation",
        "tombstone_resource",
        "tombstone_entity",
        "tombstone_entity_branch",
        "tombstone_relation",
        "commit",
        "merge",
        "revert",
        "review",
        "approve",
        "assign_user_role",
        "revoke_user_role",
        "create_root_entity",
        "delete_root_entity"
      ]
    },
    "AdminMemoryAction": {
      "type": "string",
      "enum": [
        "assign_user_role",
        "revoke_user_role",
        "create_root_entity",
        "delete_root_entity"
      ]
    },
    "User": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName",
        "status",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string"
        },
        "status": {
          "enum": [
            "active",
            "disabled"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "AgentIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "ownerUserId",
        "agentType",
        "displayName",
        "status",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "ownerUserId": {
          "type": "string",
          "minLength": 1
        },
        "agentType": {
          "enum": [
            "main_agent",
            "sub_agent",
            "tool_agent",
            "import_agent",
            "curator_agent",
            "review_agent"
          ]
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "active",
            "disabled"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "PermissionConstraint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowedTags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "deniedTags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "allowedRelationTypes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MemoryRelationType"
          },
          "uniqueItems": true
        },
        "deniedRelationTypes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MemoryRelationType"
          },
          "uniqueItems": true
        },
        "allowRootEntityMutation": {
          "type": "boolean"
        },
        "maxRelationExpansionDepth": {
          "type": "integer",
          "minimum": 0
        },
        "requireHumanApproval": {
          "type": "boolean"
        }
      }
    },
    "Permission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "resourceKind"
      ],
      "properties": {
        "action": {
          "$ref": "#/$defs/MemoryAction"
        },
        "resourceKind": {
          "$ref": "#/$defs/MemoryObjectKind"
        },
        "constraints": {
          "$ref": "#/$defs/PermissionConstraint"
        }
      }
    },
    "Role": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "kind",
        "permissions",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "built_in",
            "custom"
          ]
        },
        "permissions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/Permission"
          }
        },
        "status": {
          "enum": [
            "active",
            "disabled"
          ]
        }
      }
    },
    "UserRootRoleAssignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "userId",
        "rootEntityId",
        "roleId",
        "assignedBy",
        "assignedAt",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "userId": {
          "type": "string",
          "minLength": 1
        },
        "rootEntityId": {
          "type": "string",
          "minLength": 1
        },
        "roleId": {
          "type": "string",
          "minLength": 1
        },
        "assignedBy": {
          "type": "string",
          "minLength": 1
        },
        "assignedAt": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "enum": [
            "active",
            "revoked"
          ]
        },
        "revokedAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "TaskScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rootEntityId"
      ],
      "properties": {
        "rootEntityId": {
          "type": "string",
          "minLength": 1
        },
        "allowedEntityIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "deniedEntityIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "allowedTags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "deniedTags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "allowedResourceIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "deniedResourceIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "relationExpansionPolicy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allowedRelationTypes": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/MemoryRelationType"
              },
              "uniqueItems": true
            },
            "maxDepth": {
              "type": "integer",
              "minimum": 0
            },
            "allowRequiredDependencies": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "AgentDelegation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "agentId",
        "ownerUserId",
        "rootEntityId",
        "permissions",
        "delegatedBy",
        "delegatedAt",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "agentId": {
          "type": "string",
          "minLength": 1
        },
        "ownerUserId": {
          "type": "string",
          "minLength": 1
        },
        "rootEntityId": {
          "type": "string",
          "minLength": 1
        },
        "permissions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/Permission"
          }
        },
        "constraints": {
          "$ref": "#/$defs/PermissionConstraint"
        },
        "delegatedBy": {
          "type": "string",
          "minLength": 1
        },
        "delegatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "enum": [
            "active",
            "revoked"
          ]
        },
        "revokedAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "PrincipalContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sessionId",
        "userId",
        "agentId",
        "rootEntityId",
        "taskScope"
      ],
      "properties": {
        "sessionId": {
          "type": "string",
          "minLength": 1
        },
        "userId": {
          "type": "string",
          "minLength": 1
        },
        "agentId": {
          "type": "string",
          "minLength": 1
        },
        "rootEntityId": {
          "type": "string",
          "minLength": 1
        },
        "taskScope": {
          "$ref": "#/$defs/TaskScope"
        },
        "delegationId": {
          "type": "string",
          "minLength": 1
        },
        "parentAgentId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "PermissionSubject": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "userId"
          ],
          "properties": {
            "kind": {
              "const": "user"
            },
            "userId": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "agentId",
            "ownerUserId"
          ],
          "properties": {
            "kind": {
              "const": "agent"
            },
            "agentId": {
              "type": "string",
              "minLength": 1
            },
            "ownerUserId": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "PermissionRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject",
        "rootEntityId",
        "action",
        "resourceKind"
      ],
      "properties": {
        "subject": {
          "$ref": "#/$defs/PermissionSubject"
        },
        "rootEntityId": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "$ref": "#/$defs/MemoryAction"
        },
        "resourceKind": {
          "$ref": "#/$defs/MemoryObjectKind"
        },
        "branchRef": {
          "type": "string",
          "minLength": 1
        },
        "entityId": {
          "type": "string",
          "minLength": 1
        },
        "resourceId": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "relationType": {
          "$ref": "#/$defs/MemoryRelationType"
        },
        "relationDepth": {
          "type": "integer",
          "minimum": 0
        },
        "taskScope": {
          "$ref": "#/$defs/TaskScope"
        }
      }
    },
    "PermissionDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed",
        "reason",
        "subjectId",
        "subjectKind",
        "rootEntityId",
        "action",
        "resourceKind",
        "matchedRoles",
        "missingActions",
        "constraints"
      ],
      "properties": {
        "allowed": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "subjectId": {
          "type": "string",
          "minLength": 1
        },
        "subjectKind": {
          "enum": [
            "user",
            "agent"
          ]
        },
        "rootEntityId": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "$ref": "#/$defs/MemoryAction"
        },
        "resourceKind": {
          "$ref": "#/$defs/MemoryObjectKind"
        },
        "matchedRoles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "missingActions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MemoryAction"
          },
          "uniqueItems": true
        },
        "constraints": {
          "$ref": "#/$defs/PermissionConstraint"
        }
      }
    },
    "MemoryEntity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "rootEntityId",
        "status",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "rootEntityId": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "enum": [
            "active",
            "archived",
            "tombstoned",
            "conflicted"
          ]
        },
        "currentBranchId": {
          "type": "string",
          "minLength": 1
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "MemoryEntityBranch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "entityId",
        "rootEntityId",
        "branchRef",
        "title",
        "description",
        "tags",
        "importance",
        "confidence",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "entityId": {
          "type": "string",
          "minLength": 1
        },
        "rootEntityId": {
          "type": "string",
          "minLength": 1
        },
        "branchRef": {
          "type": "string",
          "minLength": 1
        },
        "parentBranchId": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "extraInfo": {
          "type": "object",
          "propertyNames": {
            "not": {
              "enum": [
                "contradicts",
                "dependsOn",
                "depends_on",
                "nextIs",
                "next_is",
                "references",
                "relations",
                "steps",
                "supersedes"
              ]
            }
          }
        },
        "importance": {
          "type": "number"
        },
        "confidence": {
          "type": "number"
        },
        "status": {
          "enum": [
            "active",
            "pending",
            "conflicted",
            "deprecated",
            "verified",
            "superseded",
            "tombstoned"
          ]
        },
        "origin": {
          "enum": [
            "cloud_snapshot",
            "local_pending",
            "resolution",
            "import"
          ]
        },
        "pendingId": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "MemoryRelation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "rootEntityId",
        "sourceId",
        "sourceKind",
        "targetId",
        "targetKind",
        "relationType",
        "weight",
        "confidence",
        "branchRef",
        "status",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "rootEntityId": {
          "type": "string",
          "minLength": 1
        },
        "sourceId": {
          "type": "string",
          "minLength": 1
        },
        "sourceKind": {
          "enum": [
            "memory_entity",
            "memory_entity_branch",
            "resource",
            "resource_chunk"
          ]
        },
        "targetId": {
          "type": "string",
          "minLength": 1
        },
        "targetKind": {
          "enum": [
            "memory_entity",
            "memory_entity_branch",
            "resource",
            "resource_chunk"
          ]
        },
        "relationType": {
          "$ref": "#/$defs/MemoryRelationType"
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "ordinal": {
          "type": "integer",
          "minimum": 0
        },
        "required": {
          "type": "boolean"
        },
        "condition": {
          "type": "object"
        },
        "weight": {
          "type": "number"
        },
        "confidence": {
          "type": "number"
        },
        "branchRef": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "active",
            "tombstoned",
            "conflicted"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "rootEntityId",
        "sourceType",
        "title",
        "contentHash",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "rootEntityId": {
          "type": "string",
          "minLength": 1
        },
        "sourceType": {
          "enum": [
            "document",
            "conversation",
            "code_repo",
            "code_file",
            "tool_output",
            "webpage",
            "ticket",
            "database_record"
          ]
        },
        "title": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        },
        "contentHash": {
          "type": "string",
          "minLength": 1
        },
        "currentRevisionId": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "active",
            "tombstoned"
          ]
        },
        "metadata": {
          "type": "object"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "ResourceChunk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "rootEntityId",
        "resourceId",
        "chunkIndex",
        "text",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "rootEntityId": {
          "type": "string",
          "minLength": 1
        },
        "resourceId": {
          "type": "string",
          "minLength": 1
        },
        "chunkIndex": {
          "type": "integer",
          "minimum": 0
        },
        "text": {
          "type": "string"
        },
        "bm25DocumentId": {
          "type": "string",
          "minLength": 1
        },
        "contentHash": {
          "type": "string",
          "minLength": 1
        },
        "headingPath": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "filePath": {
          "type": "string"
        },
        "startLine": {
          "type": "integer",
          "minimum": 1
        },
        "endLine": {
          "type": "integer",
          "minimum": 1
        },
        "tokenCount": {
          "type": "integer",
          "minimum": 0
        },
        "origin": {
          "enum": [
            "cloud_snapshot",
            "local_pending",
            "resolution",
            "import"
          ]
        },
        "pendingId": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "enum": [
            "active",
            "tombstoned"
          ]
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "headingPath": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "filePath": {
              "type": "string"
            },
            "startLine": {
              "type": "integer",
              "minimum": 1
            },
            "endLine": {
              "type": "integer",
              "minimum": 1
            },
            "tokenCount": {
              "type": "integer",
              "minimum": 0
            },
            "revisionId": {
              "type": "string",
              "minLength": 1
            },
            "contentHash": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "ResourceRevision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "resourceId",
        "rootEntityId",
        "commitId",
        "contentHash",
        "createdAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "resourceId": {
          "type": "string",
          "minLength": 1
        },
        "rootEntityId": {
          "type": "string",
          "minLength": 1
        },
        "commitId": {
          "type": "string",
          "minLength": 1
        },
        "parentRevisionId": {
          "type": "string",
          "minLength": 1
        },
        "contentHash": {
          "type": "string",
          "minLength": 1
        },
        "metadata": {
          "type": "object"
        },
        "createdAt": {
          "type": "string",
