# Runtime memory configuration lives in config/*.json.
# Start local tools with: npm run team -- --config config/team-memory.local.json <command>
PORT=3000
TEAM_MEMORY_TOKEN=
ADMIN_TOKEN=
TEAM_MEMORY_SESSION_FILE=./.data/local/session.json
DEV_ROOT_ENTITY_ID=root:development
DEV_USER_ID=user:developer
DEV_USER_NAME=Developer
DEV_SESSION_ID=session:developer
