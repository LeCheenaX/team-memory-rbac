{
  "name": "team-memory-rbac",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "team-memory": "scripts/team-memory.mjs",
    "team-memory-server": "scripts/dev-server.mjs",
    "team-memory-mcp": "scripts/team-memory-mcp.mjs",
    "openclaw-team-memory": "scripts/openclaw-team-memory.mjs"
  },
  "scripts": {
    "contracts:generate": "node --experimental-strip-types scripts/generate-contracts.mjs",
    "test": "node --experimental-strip-types --test --test-concurrency=1 --test-timeout=120000 --test-force-exit test/*.test.ts",
    "test:hermes-contract": "python -m unittest discover -s test/hermes -p \"test_*.py\"",
    "typecheck": "tsc --noEmit",
    "check:deps": "node scripts/check-dependencies.mjs",
    "migrations:validate": "node scripts/validate-migrations.mjs",
    "smoke:dev": "node --experimental-strip-types scripts/smoke-dev.mjs",
    "dev:init": "node --experimental-strip-types scripts/dev-init.mjs",
    "bootstrap:root-admin": "node --experimental-strip-types scripts/bootstrap-root-admin.mjs",
    "dev:server": "node --experimental-strip-types scripts/dev-server.mjs",
    "local-host-smoke": "node --experimental-strip-types scripts/local-host-smoke.mjs",
    "local-memory-tool": "node --experimental-strip-types scripts/local-memory-tool.mjs",
    "hermes:local-smoke": "node --experimental-strip-types scripts/hermes-local-smoke.mjs",
    "mcp:stdio": "node --experimental-strip-types scripts/team-memory-mcp.mjs",
    "openclaw": "node --experimental-strip-types scripts/openclaw-team-memory.mjs",
    "team": "node --experimental-strip-types scripts/team-memory.mjs",
    "check": "npm run check:deps && npm run typecheck && npm test && npm run test:hermes-contract"
  },
  "engines": {
    "node": ">=22.13"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@libsql/client": "^0.15.8"
  }
}
